# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Connection - Get from MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/obsidian

# CORS Configuration - Your Vercel frontend URL
CLIENT_URL=https://your-frontend-domain.vercel.app

# Public API URL for frontend clients
API_PUBLIC_URL=https://your-backend-domain.onrender.com
